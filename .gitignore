# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.egg-info/
dist/
build/

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Environment & secrets ──────────────────────────────────────────────────────
.env
.env.*

# ── Tool caches ────────────────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/

# ── Jupyter ────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
jupyter_execute/

# ── Data — raw inputs (immutable, sourced externally) ─────────────────────────
data/raw/

# ── Data — pipeline outputs (regenerated by running main.py) ──────────────────
data/cleaned/
data/enriched/

# ── Generated outputs ──────────────────────────────────────────────────────────
outputs/
notebooks/**/outputs/

# ── Logs (all levels) ─────────────────────────────────────────────────────────
**/logs/

# ── OS artefacts ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
